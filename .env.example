# =============================================================================
# DropToDrop Environment Variables
# Copy this to .env and fill in actual values. Never commit .env.
# =============================================================================

# --- Shopify App ---
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_fulfillments,write_fulfillments,read_inventory,write_inventory,read_shipping
SHOPIFY_APP_URL=https://your-app.example.com
SHOPIFY_REDIRECT_URI=https://your-app.example.com/auth/callback

# --- Server ---
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
APP_ENV=development
LOG_LEVEL=debug

# --- Database ---
DATABASE_URL=postgres://droptodrop:droptodrop@localhost:5432/droptodrop?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_RETRIES=3

# --- Session ---
SESSION_SECRET=generate_a_32_byte_random_hex_string
SESSION_MAX_AGE=86400

# --- Webhook ---
WEBHOOK_SECRET=your_webhook_secret_here

# --- Encryption ---
ENCRYPTION_KEY=generate_a_32_byte_hex_key_for_aes256

# --- Rate Limiting ---
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# --- Worker ---
WORKER_CONCURRENCY=5
WORKER_RETRY_MAX=3
WORKER_RETRY_DELAY=5s

# --- Frontend ---
VITE_SHOPIFY_API_KEY=your_api_key_here
VITE_APP_URL=https://your-app.example.com
